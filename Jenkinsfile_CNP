#!groovy

@Library("Infrastructure")

import uk.gov.hmcts.contino.AppPipelineDsl
import uk.gov.hmcts.contino.GithubAPI
import uk.gov.hmcts.contino.GradleBuilder

def type = "java"
def product = "pt"
def component = "api"


def secrets = [
  'pt-kv-${env}': [
    secret('pt-api-s2s-secret', 'PT_API_S2S_SECRET'),
    secret('definition-importer-username', 'DEFINITION_IMPORTER_USERNAME'),
    secret('definition-importer-password', 'DEFINITION_IMPORTER_PASSWORD'),
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

GradleBuilder builder = new GradleBuilder(this, product)

withPipeline(type, product, component) {
  def githubApi = new GithubAPI(this)
  env.IDAM_S2S_AUTH_URL = "http://rpe-service-auth-provider-aat.service.core-compute-aat.internal"
  env.IDAM_API_URL = "https://idam-api.aat.platform.hmcts.net"
  loadVaultSecrets(secrets)
  enableDbMigration('pt-kv')

  onPR() {
    setPreviewEnvVars()
    if (githubApi.getLabelsbyPattern(env.BRANCH_NAME, "pr-values:ccd").size() > 0) {
      env.CCD_ENABLED = "true"
      enableHighLevelDataSetup("pt-kv")
    } else {
      env.CCD_ENABLED = "false"
    }
    onMaster() {
      setAatEnvVars()
      enableHighLevelDataSetup("", true)
    }
  }

  before('highleveldatasetup') {
    onPR{
      env.DEFINITION_STORE_URL_BASE = "https://ccd-definition-store-pt-api-pr-${CHANGE_ID}.preview.platform.hmcts.net"
      env.CASE_API_URL = "https://pt-api-pr-${CHANGE_ID}.preview.platform.hmcts.net"
      env.DATA_STORE_URL_BASE="https://ccd-data-store-api-pt-api-pr-${CHANGE_ID}.preview.platform.hmcts.net"
    }
    onMaster{
      env.DEFINITION_STORE_URL_BASE = "http://ccd-definition-store-api-aat.service.core-compute-aat.internal"
      env.DATA_STORE_URL_BASE="http://ccd-data-store-api-aat.service.core-compute-aat.internal"
      env.CASE_API_URL = "https://pt-api-staging.aat.platform.hmcts.net"
      env.CASE_TYPE_SUFFIX="staging"
      generateDefinitions(builder)
      env.CASE_API_URL = "http://pt-api-aat.service.core-compute-aat.internal"
      env.CASE_TYPE_SUFFIX=""
    }
    generateDefinitions(builder)
  }
}
def setPreviewEnvVars() {
  // TODO: Update URL to include XUI when available
  env.TEST_E2E_URL_WEB = "https://pt-api-pr-${CHANGE_ID}.preview.platform.hmcts.net"
  env.ENVIRONMENT= "preview"
}

def setAatEnvVars() {
  env.TEST_E2E_URL_WEB = "https://manage-case.aat.platform.hmcts.net/"
  env.ENVIRONMENT= "aat"
}

def generateDefinitions(builder) {
  builder.gradle('--rerun-tasks generateCCDConfig')
  sh "./bin/create-xlsx.sh ${env.ENVIRONMENT}"
  steps.archiveArtifacts artifacts: "build/definitions/*.xlsx"
}


def runE2eTests(String context) {
  try {
    stage('E2E Test - ' + context) {
      sh './gradlew runE2eTests'
    }
  } finally {
    publishHTML([
      allowMissing: true,
      alwaysLinkToLastBuild: true,
      keepAll: true,
      reportDir: "src/e2eTest/playwright-report",
      reportFiles: 'index.html',
      reportName: 'E2E Test Report'
    ])
    steps.archiveArtifacts allowEmptyArchive: true, artifacts: 'definitions/test/playwright-report/**'
  }
}
